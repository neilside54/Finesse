# Finesse Chess Analysis -- Environment Variables

# Copy this file to .env
#   cp .env.example .env

# Django
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=localhost,yourdomain.com
FRONTEND_URL=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database
DATABASE_URL=postgres://finesse:finesse_password@db:5432/finesse

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CACHES_DEFAULT_LOCATION=redis://redis:6379/1

# Celery
CELERY_CONCURRENCY=2

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=1800

# Stockfish
STOCKFISH_PATH=stockfish

# Railway auto-sets PORT; leave empty for local dev (defaults to 8001)
PORT=

# Service mode
# Options: web | worker | beat
SERVICE=web
