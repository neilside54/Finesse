# ── Finesse Chess Analysis — Environment Variables ──────────────────
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env
#   docker compose up -d

# ── Django ──────────────────────────────────────────────────────────
# Generate a strong secret key:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to "false" in production!
DEBUG=false

# Comma-separated list of allowed host/domain names
ALLOWED_HOSTS=localhost,yourdomain.com

# The public URL of your frontend (no trailing slash)
FRONTEND_URL=https://yourdomain.com

# Comma-separated list of origins allowed for CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Comma-separated list of origins allowed for CSRF
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── Database (PostgreSQL) ──────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://finesse:finesse_password@db:5432/finesse

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Cache ───────────────────────────────────────────────────────────
CACHES_DEFAULT_LOCATION=redis://redis:6379/1

# ── Celery ──────────────────────────────────────────────────────────
CELERY_CONCURRENCY=2

# ── Gunicorn ────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=1800

# ── Stockfish ───────────────────────────────────────────────────────
# In Docker, Stockfish is installed via apt — no need to set this.
# On Windows dev, it defaults to engines/stockfish.exe
STOCKFISH_PATH=stockfish
