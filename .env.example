# ── Finesse Chess Analysis — Environment Variables ──────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Lichess OAuth (https://lichess.org/account/oauth/app)
# Lichess uses your own generated random strings — no registration needed.
LICHESS_OAUTH_CLIENT_ID=your-random-lichess-client-id
LICHESS_OAUTH_CLIENT_SECRET=your-random-lichess-client-secret

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Cache (Redis DB 1)
CACHE_LOCATION=redis://127.0.0.1:6379/1
